{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Condition": {
        "StringEquals": {
          "aws:PrincipalAccount": "$account"
        }
      },
      "Action": [
        "s3:Abort*",
        "s3:DeleteObject*",
        "s3:GetBucket*",
        "s3:GetObject*",
        "s3:GetEncryptionConfiguration",
        "s3:List*",
        "s3:PutObject*"
      ],
      "Resource": [
        "arn:aws:s3:::tinstafl-$alias",
        "arn:aws:s3:::tinstafl-$alias/*"
      ],
      "Effect": "Allow"
    }
  ]
}
