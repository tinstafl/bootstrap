{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": "servicequotas:GetServiceQuota",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "servicequotas:ServiceCode": [ "ec2" ]
        }
      }
    },
    {
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": [
        "arn:aws:secretsmanager:$region:$account:secret:tinstafl-grafana-$alias*"
      ]
    }
  ]
}
