{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Condition": {
        "StringEquals": {
          "aws:PrincipalAccount": "$account"
        }
      },
      "Action": [
        "iam:CreateRole",
        "iam:AttachRolePolicy",
        "iam:CreateServiceLinkedRole",
        "iam:GetRole",
        "iam:ListRolePolicies",
        "iam:ListAttachedRolePolicies",
        "iam:PutRolePolicy",
        "iam:GetRolePolicy",
        "iam:TagRole",
        "iam:TagUser",
        "iam:TagGroup",
        "iam:TagPolicy"
      ],
      "Resource": [ "*" ],
      "Effect": "Allow"
    },
    {
      "Effect": "Allow",
      "Action": [ "iam:PassRole" ],
      "Resource": [ "*" ],
      "Condition": {
        "StringEquals": {
          "aws:PrincipalAccount": "$account"
        }
      }
    }
  ]
}
