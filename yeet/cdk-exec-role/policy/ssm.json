{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Condition": {
        "StringEquals": {
          "aws:PrincipalAccount": "$account"
        }
      },
      "Action": [
        "ssm:PutParameter",
        "ssm:PutParameters",
        "ssm:GetParameters",
        "ssm:AddTagsToResource"
      ],
      "Resource": [ "*" ],
      "Effect": "Allow"
    }
  ]
}
