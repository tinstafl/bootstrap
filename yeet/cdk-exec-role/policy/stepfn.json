{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Condition": {
        "StringEquals": {
          "aws:PrincipalAccount": "$account"
        }
      },
      "Action": [
        "states:CreateStateMachine",
        "states:DescribeStateMachine",
        "states:TagResource"
      ],
      "Resource": [ "*" ],
      "Effect": "Allow"
    }
  ]
}
